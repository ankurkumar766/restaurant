<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>About Our Restaurant</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/marquee.css">
  
  <link rel="stylesheet" href="/css/about.css" />
</head>
<body>
  <%- include("../partials/marquee") %>

<!-- Navbar -->
<nav class="navbar">
  <div class="logo">🍽️ Restaurant</div>
 
</nav>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <h1>Welcome to  Restaurant</h1>
    <p>Where Taste Meets Perfection</p>
    <button onclick="scrollToAbout()">Explore More</button>
  </div>
</section>

<!-- About Section -->
<section class="about" id="about">
  <div class="about-container">
    
    <div class="about-image">
      <img src="https://images.unsplash.com/photo-1555396273-367ea4eb4db5" alt="restaurant">
    </div>

    <div class="about-text">
      <h2>About Us</h2>
      <p>
        Our restaurant was founded in 2020 with the mission to deliver the best dining experience.
        We provide delicious food, premium service, and unforgettable memories.
      </p>

      <div class="stats">
        <div class="stat">
          <h3 class="counter" data-target="500">99</h3>
          <p>Happy Customers</p>
        </div>

        <div class="stat">
          <h3 class="counter" data-target="120">90</h3>
          <p>Dishes</p>
        </div>

        <div class="stat">
          <h3 class="counter" data-target="5">5</h3>
          <p>Years Experience</p>
        </div>
      </div>

    </div>

  </div>
</section>

<!-- Chef Section -->
<section class="chef">
  <h2>Meet Our Chef</h2>
  <div class="chef-card">
    <img src="https://images.unsplash.com/photo-1600891964599-f61ba0e24092">
    <h3>Chef Ankur</h3>
    <p>Expert in Italian and Indian Cuisine</p>
  </div>
</section>

<!-- Footer -->
<%- include("../partials/footer") %>



</body>
</html>