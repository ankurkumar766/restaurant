<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restaurants</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEj<replace_with_actual_hash>2g/rB2f+1"
          crossorigin="anonymous">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
          integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkcmfRyVX3pBnMFcV7oQPJkl9QevSCWr3W6A=="
          crossorigin="anonymous"
          referrerpolicy="no-referrer" />

    <link rel="stylesheet" href="/css/style.css" /> 
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/marquee.css">
     <!-- ✅ PWA Support -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4CAF50">
</head>
<body>
     <%- include("../partials/marquee") %>
   
  <nav class="navbar">

<div class="container nav-container">

<div class="logo">

<i class="fa-solid fa-utensils"></i>

<span>Vatika Food</span>

</div>

<div class="search-box">

<i class="fa-solid fa-magnifying-glass"></i>

<input
type="text"
id="searchInput"
placeholder="Search food, pizza, burger..."
>

</div>

<div class="menu-items">

<% if(!currentUser){ %>

<a href="/signup">
<i class="fa-solid fa-user-plus"></i>
Signup
</a>

<a href="/login">
<i class="fa-solid fa-right-to-bracket"></i>
Login
</a>

<a href="/about">
<i class="fa-solid fa-circle-info"></i>
About
</a>

<% } %>

<% if(currentUser){ %>

<a href="/my-orders">
<i class="fa-solid fa-box"></i>
Orders
</a>

<a href="/cart" class="cart">

<i class="fa-solid fa-bag-shopping"></i>card



</a>

<a href="/logout">
<i class="fa-solid fa-right-from-bracket"></i>
Logout
</a>

<% } %>

</div>

</div>

</nav>

<section class="hero">

    <div class="overlay">
        <h1>Delicious Food Delivered Fast</h1>

        <p>Delivery within 5 KM • Koderma</p>

        <a href="#menu" class="btn-order">
            Order Now
        </a>
    </div>

</section>

<!-- Hero khatam -->

<section class="menu-section" id="menu">

    <div class="container">

        <h2 class="menu-title">
            🍽️ Our Popular Menu
        </h2>

        <p class="menu-subtitle">
            Fresh • Delicious • Fast Delivery
        </p>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">

            <% for(let listing of allListings){ %>

            <div class="col">

                <div class="card listing-card h-100">

                    <img src="<%= listing.image.url %>" class="card-img-top" alt="<%= listing.title %>">

                    <div class="card-body">

                        <h5 class="card-title"><%= listing.title %></h5>

                        <h4 class="price">
                            ₹ <%= listing.price.toLocaleString("en-IN") %>
                        </h4>

                        <div class="d-flex justify-content-between mt-3">

                            <a href="/listings/<%= listing._id %>" class="btn btn-warning">
                                View
                            </a>

                            <form action="/cart/<%= listing._id %>" method="POST" class="d-inline">
    <button type="submit" class="btn btn-success">
        <i class="fa-solid fa-cart-shopping"></i>
    </button>
</form>
                        </div>

                    </div>

                </div>

            </div>

            <% } %>

        </div>

    </div>

</section>

</section>
     <section id="about">
        <div class="about-wrapper container">
            <div class="about-text">
                <p class="small">About Us</p>
                <h2>We've beem making healthy food last for 1 year</h2>
                <p>
                   In our restaurant, we serve fresh and delicious food with a wide variety of 
                   Indian, Chinese, and Continental dishes. A comfortable ambiance, quick service, 
                       and affordable prices are the highlights of our place. It’s the perfect spot to 
                  enjoy with family, friends, and to make special occasions memorable.
</p>

            </div>
            
        </div>
    </section>


   <section class="address-section">
  <h2><i class="fa-solid fa-location-dot"></i> Restaurant Address</h2>
  <p><strong> The Family Restaurant</strong><br>
     Opposite Girls High School, Near Shri Ram Chowk, Dhab Road, Domchanch, Koderma – 825407
  </p>

  <iframe
    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3665.422726323363!2d85.77372607510464!3d24.34592147829576!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x39f2a9a3d5f5d4c1%3A0x4a9f21b66c83d71a!2sVATIKA%20The%20Family%20Restaurant!5e0!3m2!1sen!2sin!4v1726847274000!5m2!1sen!2sin"
    width="100%" height="350" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
  </iframe>
</section><br><br><br><br><br><br><br><br><br><br><br><br><br>




<%- include("../partials/footer") %>


<script>
   const searchInput = document.getElementById("searchInput");

searchInput.addEventListener("keyup", function () {

    const query = this.value.trim().toLowerCase();

    const cards = document.querySelectorAll(".listing-card");

    cards.forEach(card => {

        const title = card.querySelector(".card-title").textContent.toLowerCase();

        const price = card.querySelector(".price")
            .textContent.replace(/[₹,\s]/g, "");

        // Agar user number likhta hai
        if (!isNaN(query) && query !== "") {

            if (parseInt(price) <= parseInt(query)) {
                card.parentElement.style.display = "";
            } else {
                card.parentElement.style.display = "none";
            }

        }

        // Agar user food name likhta hai
        else {

            if (title.includes(query) || price.includes(query)) {
                card.parentElement.style.display = "";
            } else {
                card.parentElement.style.display = "none";
            }

        }

    });

});
</script>

</body>
</html>