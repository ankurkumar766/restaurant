    <h3 style="color: blue;">Munu Details:- </h3>
    <div class="row">
      <div class="col-8 offest-2">

     
     <h3><%= listing.title %> :</h3>
    </div>
    <div class=" card col-6 offset-2 show-card listing-card">
       <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
     <div class="card-body">
      <p class="card-text">
      
      <b><%= listing.title %></p> </b>
      
     </div>
    </div>
    <ul>
      <li><%= listing.title %></li>
      
      <br/>
      <li><%= listing.description %></li>
       <li> &#8377; <%= listing.price.toLocaleString("en-IN") %></li>
      
     
    </ul>
    <h2>Delivery charges :-  &#8377; 40</h2>
    
    <% if(!currentUser){ %>
         <!-- <a class="nav-link " href="/signup"><b>Buy Now</b></a> -->
          <a href="/signup" class="buy-btn">Buy Now</a>
          

        <h1 style="color: #ff0000;">please signup for buy the food</h1>
      
    <% } %>
    

    <% if(currentUser){ %>
   <a href="/listings/<%= listing._id %>/buy" class="buy-btn">Buy Now</a>&nbsp; &nbsp;
   
    <a href="/listings/<%= listing._id %>/cancle" class="can-btn">Cancle</a>&nbsp; &nbsp;&nbsp;</br></br>
       

      

    <form action="/cart/<%= listing._id %>" method="POST">
    <button class="add " >
        Add to Bag 🛒
    </button>
</form>



   
    
    <h2>₹500 से ज्यादा के ऑर्डर पर डिलीवरी फ्री</h2>

   
   
   
   <%} %></br>
    </br> </br>




