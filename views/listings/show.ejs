<h2 class="related-title">Related Menu 🍔</h2>

<div class="related-container">

<% relatedListings.forEach(item => { %>

<a href="/listings/<%= item._id %>" class="related-card-link">

<div class="related-card">

<img src="<%= item.image.url %>" class="related-img">

<div class="related-body">

<h5><%= item.title %></h5>

<p>₹ <%= item.price.toLocaleString("en-IN") %></p>

</div>

</div>

</a>

<% }) %>

</div>

   


